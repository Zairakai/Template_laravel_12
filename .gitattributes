# Default: treat everything as text and normalize EOL to LF
* text=auto eol=lf

# Syntax-aware diffs
*.md         diff=markdown
*.php        diff=php
*.blade.php  diff=html
*.html       diff=html
*.vue        diff=html
*.css        diff=css
*.scss       diff=css

# Makefiles: tabs are required in recipes
Makefile text eol=lf
*.mk     text eol=lf

# Git hooks
.githooks/* text eol=lf

# Binary — no diffs, no EOL conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
