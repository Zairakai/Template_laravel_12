# Docker Image Versions
# ======================
PHP_IMAGE=zairakai/php:latest-dev
NODE_IMAGE=zairakai/node:latest-dev
NGINX_IMAGE=nginx:1.26-alpine
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7.4-alpine
MAILPIT_IMAGE=axllent/mailpit:latest
MINIO_IMAGE=minio/minio:RELEASE.2025-03-12T18-04-18Z

# Application
# ======================
APP_SLUG={{APP_SLUG}}

APP_NAME="{{APP_NAME}}"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logs
# ======================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
# ======================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE={{APP_SLUG}}
DB_USERNAME=app
DB_PASSWORD=password

FORWARD_DB_PORT=3306

# Cache / Queue / Session
# ======================
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE={{APP_SLUG}}_session

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

FORWARD_REDIS_PORT=6379

# Mail
# ======================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@localhost"
MAIL_FROM_NAME="${APP_NAME}"

FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025

# Storage (MinIO / S3)
# ======================
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET={{APP_SLUG}}
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
FORWARD_MINIO_PORT=9000
FORWARD_MINIO_CONSOLE_PORT=9001

# Broadcast
# ======================
BROADCAST_CONNECTION=log

# Vite
# ======================
VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5173
VITE_SOURCEMAP=false

# API
# ======================
API_THROTTLE_MAX_ATTEMPTS=60
API_THROTTLE_DECAY_MINUTES=1

# Seeding
# ======================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
DEFAULT_PASSWORD=password

# zairakai/laravel-eloquent
# ======================
ELOQUENT_LOGGING_ENABLED=true
ELOQUENT_LOGGING_CHANNEL=
ELOQUENT_LOG_LEVEL_DEPRECATED=warning
ELOQUENT_LOG_LEVEL_MISSING=info
ELOQUENT_LOGGING_BACKTRACE=true
ELOQUENT_LOGGING_BACKTRACE_DEPTH=5
ELOQUENT_REQUEST_CACHE=false
