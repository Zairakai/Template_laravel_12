APP_NAME=Laravel
APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite in-memory — no external service needed
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

MAIL_MAILER=array

BROADCAST_CONNECTION=null

FILESYSTEM_DISK=local

# Disable logging noise from zairakai/laravel-eloquent during tests
ELOQUENT_LOGGING_ENABLED=false
ELOQUENT_LOGGING_BACKTRACE=false

# Throttle — relaxed for test suite
API_THROTTLE_MAX_ATTEMPTS=1000
API_THROTTLE_DECAY_MINUTES=1

# Seeding
DEFAULT_PASSWORD=password
